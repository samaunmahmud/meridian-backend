# Maven build output — regenerated by `mvn`, never hand-edit or commit it
target/

# IntelliJ project files — machine-specific, everyone's IDE config differs
.idea/
*.iml

# VS Code (in case you use it for the frontend later, or peek at backend files in it)
.vscode/

# OS clutter
.DS_Store
Thumbs.db

# Environment/secrets — API keys, DB passwords. NEVER commit these.
.env
application-local.properties
